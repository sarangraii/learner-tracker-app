PORT=4000
NODE_ENV=development

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=learner_track_db

# Alternatively a single connection string (takes precedence if set)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/learner_track_db

# Comma separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:3000
